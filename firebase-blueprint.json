{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User account information and balance",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "balance": { "type": "number" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "balance", "role"]
    },
    "DepositRequest": {
      "title": "Deposit Request",
      "description": "A request to add funds via USDT",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "amount": { "type": "number" },
        "method": { "type": "string" },
        "proofUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "amount", "status"]
    },
    "MarketplaceItem": {
      "title": "Marketplace Item",
      "description": "Partner logos and links",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "logoUrl": { "type": "string" },
        "redirectLink": { "type": "string" }
      },
      "required": ["name", "logoUrl"]
    },
    "SupportTicket": {
      "title": "Support Ticket",
      "description": "User support requests with optional screenshot and messaging history",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "subject": { "type": "string" },
        "message": { "type": "string" },
        "screenshotUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["open", "in-progress", "closed"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "messages": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "senderId": { "type": "string" },
              "senderRole": { "type": "string", "enum": ["user", "admin"] },
              "text": { "type": "string" },
              "createdAt": { "type": "string", "format": "date-time" }
            }
          }
        },
        "hasNewAdminReply": { "type": "boolean" },
        "hasNewUserReply": { "type": "boolean" }
      },
      "required": ["userId", "subject", "message", "status"]
    },
    "WithdrawRequest": {
      "title": "Withdraw Request",
      "description": "A request to withdraw funds via TRC20",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "amount": { "type": "number" },
        "address": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "success", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "amount", "address", "status"]
    },
    "Product": {
      "title": "Product",
      "description": "E-commerce product information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "image": { "type": "string" },
        "stock": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "stock"]
    },
    "EcomOrder": {
      "title": "E-commerce Order",
      "description": "Order for a physical product",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "productId": { "type": "string" },
        "productName": { "type": "string" },
        "price": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "processing", "shipped", "delivered"] },
        "shippingAddress": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "address": { "type": "string" },
            "city": { "type": "string" },
            "zipCode": { "type": "string" },
            "phone": { "type": "string" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "productId", "price", "status", "shippingAddress"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Individual user profiles"
    },
    "/deposits/{depositId}": {
      "schema": "DepositRequest",
      "description": "Deposit requests for admin review"
    },
    "/marketplace/{itemId}": {
      "schema": "MarketplaceItem",
      "description": "Marketplace partner data"
    },
    "/tickets/{ticketId}": {
      "schema": "SupportTicket",
      "description": "Support tickets for user assistance"
    },
    "/withdraws/{withdrawId}": {
      "schema": "WithdrawRequest",
      "description": "Withdraw requests for admin review"
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Store products"
    },
    "/ecom_orders/{orderId}": {
      "schema": "EcomOrder",
      "description": "E-commerce orders"
    }
  }
}
